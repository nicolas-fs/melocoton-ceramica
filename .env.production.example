# ============================================================
# MELOCOTÓN CERÁMICA — Variables de entorno PRODUCCIÓN
# Cargar en Vercel: Settings → Environment Variables
# NO subir este archivo a Git con valores reales
# ============================================================

# ── URLs ───────────────────────────────────────────────────
NEXT_PUBLIC_URL=https://melocoton-ceramica.vercel.app
NEXTAUTH_URL=https://melocoton-ceramica.vercel.app
SITE_URL=https://melocoton-ceramica.vercel.app

# ── NextAuth ───────────────────────────────────────────────
# Generar en: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=REEMPLAZAR_CON_SECRET_REAL

# ── Admin ──────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REEMPLAZAR_CON_PASSWORD_SEGURA

# ── Mercado Pago (PRUEBA) ──────────────────────────────────
# Obtener en: mercadopago.com.ar/developers → Credenciales de prueba
MERCADO_PAGO_ACCESS_TOKEN=TEST-REEMPLAZAR
MERCADO_PAGO_PUBLIC_KEY=TEST-REEMPLAZAR
# Para PRODUCCIÓN cambiar por APP_USR-... y la public key de producción

# ── Mercado Pago Webhook ───────────────────────────────────
# Generar un string aleatorio para validar webhooks
MERCADO_PAGO_WEBHOOK_SECRET=REEMPLAZAR_CON_STRING_ALEATORIO

# ── WhatsApp (CallMeBot) ───────────────────────────────────
# Número que RECIBE las notificaciones de pedidos (con prefijo 549)
CALLMEBOT_PHONE=549XXXXXXXXXX
CALLMEBOT_APIKEY=REEMPLAZAR_CON_APIKEY

# WhatsApp del dueño (Ignacio) — recibe copia de cada venta
ADMIN_WHATSAPP=549XXXXXXXXXX

# ── Email (Resend) ─────────────────────────────────────────
RESEND_API_KEY=re_REEMPLAZAR
RESEND_FROM_EMAIL=Melocotón Cerámica <pedidos@melocotonceramica.com.ar>
EMAIL_FROM=Melocotón Cerámica <pedidos@melocotonceramica.com.ar>
EMAIL_ADMIN=ignacio@email.com

# ── Chatbot IA (opcional) ─────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-REEMPLAZAR

# ── Stock ─────────────────────────────────────────────────
STOCK_ALERTA_UMBRAL=3
