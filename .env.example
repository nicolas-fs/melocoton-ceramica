# ============================================================
# MELOCOTÓN CERÁMICA — Variables de entorno
#
# Para desarrollo local:
#   Ya tenés un .env.local listo para usar con credenciales
#   de prueba. Solo ejecutá: npm install && npm run dev
#
# Para Vercel (producción):
#   Cargá cada variable en: Settings → Environment Variables
#   Leé el archivo PRODUCCION.md para instrucciones completas.
# ============================================================


# ── URL del sitio ──────────────────────────────────────────
# Desarrollo: dejá así
NEXT_PUBLIC_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
# Producción: cambiar por tu URL de Vercel o dominio propio
# NEXT_PUBLIC_URL=https://melocotonceramica.vercel.app
# NEXTAUTH_URL=https://melocotonceramica.vercel.app


# ── Seguridad de sesión (NextAuth) ─────────────────────────
# Para producción: generá uno nuevo en https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=melocoton-ceramica-secret-cambiar-en-produccion


# ── Credenciales del panel admin ──────────────────────────
# Con estos datos entrás a: tu-sitio.com/admin-login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=melocoton2024
# ↑ En producción cambiá la contraseña por algo más seguro


# ── Mercado Pago ───────────────────────────────────────────
# Dónde obtenerlo:
#   mercadopago.com.ar/developers → tu app → Credenciales
#
# Prueba (sin dinero real):
#   MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxx
# Producción (cobros reales):
#   MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx
#
# MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxx


# ── WhatsApp automático ────────────────────────────────────
# Al entrar un pedido te llega un WhatsApp con todo el detalle.
# Gratis. Configuración: leer PRODUCCION.md Parte 3.
#
# Formato del número: 549 + código de área sin 0 + número sin 15
# Ejemplo Carlos Paz (0354): CALLMEBOT_PHONE=5493542XXXXXXX
#
# CALLMEBOT_PHONE=549XXXXXXXXXX
# CALLMEBOT_APIKEY=XXXXXX


# ── Email de comprobante al cliente ───────────────────────
# El cliente recibe un email con su comprobante al comprar.
# Gratis hasta 3.000 emails/mes con Resend (resend.com).
# Instrucciones: leer PRODUCCION.md Parte 4.
#
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=Melocotón Cerámica <pedidos@melocotonceramica.com.ar>
# EMAIL_ADMIN=tu@email.com


# ── Chatbot con IA (completamente opcional) ───────────────
# Sin esta variable el chatbot responde preguntas básicas igual.
# Con esta variable usa IA real y conoce tus productos.
# Obtenerla en: console.anthropic.com → API Keys
#
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx


# ── Alertas de stock bajo ─────────────────────────────────
# Te avisa cuando un producto tiene pocas unidades.
# 3 = te avisa cuando queden 3 unidades o menos.
STOCK_ALERTA_UMBRAL=3
